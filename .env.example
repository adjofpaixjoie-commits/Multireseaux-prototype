# Copiez ce fichier en ".env" et remplissez vos propres cles

# --- Telegram ---
# Obtenu via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=
# ID du canal ou chat ou publier (ex: @moncanal ou -1001234567890)
TELEGRAM_CHAT_ID=

# --- X (Twitter) ---
# Obtenus sur https://developer.x.com (acces pay-per-use ou legacy)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- Serveur ---
PORT=3000
